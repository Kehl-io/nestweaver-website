    "@tailwindcss/vite": "^4.2.0",
    "@types/node": "^26.0.0",
    "eslint": "^9.39.0",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.8.0",
