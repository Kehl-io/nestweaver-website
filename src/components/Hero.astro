---
import { Image } from 'astro:assets';
import raptorIcon from '@/assets/logo-icon-dark.svg';
---

<section class="hero-section relative flex min-h-[85vh] items-center overflow-hidden">
  <div class="relative z-10 mx-auto w-full max-w-5xl px-6 py-20 md:px-8">
    <div class="flex flex-col items-center text-center">
      <Image
        src={raptorIcon}
        alt=""
        aria-hidden="true"
        width={96}
        height={96}
        class="mb-8 opacity-90"
        loading="eager"
      />
      <h1
        class="font-display text-ink-50 mb-4 text-4xl leading-tight font-semibold md:text-5xl lg:text-6xl"
      >
        Your codebase as a queryable graph
      </h1>
      <p class="text-ink-300 mb-8 max-w-[56ch] text-lg leading-relaxed md:text-xl">
        Built for AI agents. Precomputed answers about symbols, dependencies, and call graphs — no
        source reading required.
      </p>
      <div
        class="border-ink-700 bg-ink-900 text-ink-100 mb-8 flex items-center gap-2 rounded-lg border px-5 py-3 font-mono text-sm"
      >
        <span class="text-ink-500 select-none" aria-hidden="true">$</span>
        <code>npm install -g @kehl-io/nestweaver</code>
      </div>
      <div class="flex flex-col items-center gap-4 sm:flex-row">
        <a
          href="https://docs.nestweaver.kehl.io/getting-started/"
          class="bg-cobalt text-ink-950 hover:bg-halo focus-visible:outline-halo inline-flex rounded-lg px-6 py-3 font-medium transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-3"
          >Get Started</a
        >
        <a
          href="https://github.com/Kehl-io/nestweaver"
          target="_blank"
          rel="noopener noreferrer"
          class="border-ink-700 text-ink-100 hover:border-cobalt hover:text-cobalt focus-visible:outline-halo inline-flex items-center gap-2 rounded-lg border px-6 py-3 font-medium transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-3"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"
            ><path
              d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"
            ></path></svg
          >
          View on GitHub
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    background: radial-gradient(
      ellipse 80% 60% at 50% 40%,
      oklch(0.82 0.13 210 / 0.06) 0%,
      transparent 70%
    );
    background: radial-gradient(
      ellipse 80% 60% at 50% 40%,
      oklch(from var(--cobalt) l c h / 0.06) 0%,
      transparent 70%
    );
  }
</style>
