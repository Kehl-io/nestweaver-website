<section class="border-ink-800 bg-ink-950 border-t px-6 py-16 md:px-8 md:py-20">
  <div class="mx-auto max-w-3xl">
    <h2 class="font-display text-ink-50 mb-8 text-center text-2xl font-semibold md:text-3xl">Get started</h2>
    <div class="border-ink-800 bg-ink-900 mb-8 rounded-xl border p-6">
      <h3 class="text-ink-50 mb-4 font-semibold">Install</h3>
      <div class="space-y-3">
        <div>
          <p class="text-ink-400 mb-1 text-xs font-medium uppercase tracking-wider">npm (recommended)</p>
          <div class="bg-ink-950 text-ink-100 rounded-lg px-4 py-2.5 font-mono text-sm"><span class="text-ink-500 select-none" aria-hidden="true">$ </span>npm install -g @kehl-io/nestweaver</div>
        </div>
        <div>
          <p class="text-ink-400 mb-1 text-xs font-medium uppercase tracking-wider">Cargo</p>
          <div class="bg-ink-950 text-ink-100 rounded-lg px-4 py-2.5 font-mono text-sm"><span class="text-ink-500 select-none" aria-hidden="true">$ </span>cargo install nestweaver</div>
        </div>
        <p class="text-ink-400 text-sm">Or download <a href="https://github.com/Kehl-io/nestweaver/releases" target="_blank" rel="noopener noreferrer" class="text-cobalt hover:text-halo underline underline-offset-2">pre-built binaries</a> for macOS and Linux, including <code class="text-halo">NestWeaver.app</code> for macOS.</p>
      </div>
    </div>
    <div class="border-ink-800 bg-ink-900 mb-8 rounded-xl border p-6">
      <h3 class="text-ink-50 mb-4 font-semibold">Setup + first index</h3>
      <div class="bg-ink-950 text-ink-100 space-y-1 rounded-lg px-4 py-3 font-mono text-sm">
        <div><span class="text-ink-500 select-none" aria-hidden="true">$ </span>nestweaver setup <span class="text-ink-500 ml-2"># configures 16 AI tools</span></div>
        <div><span class="text-ink-500 select-none" aria-hidden="true">$ </span>nestweaver index . <span class="text-ink-500 ml-2"># parses your codebase</span></div>
      </div>
    </div>
    <div class="text-center">
      <a href="https://docs.nestweaver.kehl.io/getting-started/" class="bg-cobalt text-ink-950 hover:bg-halo focus-visible:outline-halo inline-flex rounded-lg px-8 py-3 font-medium transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-3">Read the full guide</a>
    </div>
  </div>
</section>
